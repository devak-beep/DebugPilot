generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String
  otp       String
  purpose   String   // "register" | "reset"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, purpose])
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  history     RequestHistory[]
  collections Collection[]
  savedRequests SavedRequest[]
}

model RequestHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  method      String
  url         String
  headers     String
  body        String?
  status      Int
  statusText  String
  response    String
  timeTaken   Int
  createdAt   DateTime @default(now())
}

model Collection {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  isPublic    Boolean  @default(false)
  shareToken  String?  @unique
  createdAt   DateTime @default(now())
  folders     Folder[]
  requests    SavedRequest[]
}

model Folder {
  id           String       @id @default(cuid())
  userId       String
  collectionId String
  collection   Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name         String
  isPublic     Boolean      @default(false)
  createdAt    DateTime     @default(now())
  requests     SavedRequest[]
}

model SavedRequest {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  method       String
  url          String
  headers      String
  body         String?
  isPublic     Boolean     @default(false)
  shareToken   String?     @unique
  collectionId String
  collection   Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  folderId     String?
  folder       Folder?     @relation(fields: [folderId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  examples     SavedExample[]
}

model SavedExample {
  id             String       @id @default(cuid())
  savedRequestId String
  savedRequest   SavedRequest @relation(fields: [savedRequestId], references: [id], onDelete: Cascade)
  name           String
  status         Int
  statusText     String
  response       String
  timeTaken      Int
  createdAt      DateTime     @default(now())
}
